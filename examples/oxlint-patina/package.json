{
  "name": "oxlint-patina-example",
  "private": true,
  "type": "module",
  "scripts": {
    "ensure:deps": "node ./scripts/ensure-built.mjs",
    "prelint": "pnpm run ensure:deps",
    "prelint:clean": "pnpm run ensure:deps",
    "prelint:json": "pnpm run ensure:deps",
    "lint": "oxlint -c .oxlintrc.json src",
    "lint:clean": "oxlint -c .oxlintrc.json src/Clean.vue",
    "lint:json": "oxlint -c .oxlintrc.json -f json src",
    "lint:unused-vars-probe": "oxlint -c .oxlintrc.unused-vars.json src/UnusedVarProbe.vue"
  },
  "devDependencies": {
    "oxlint": "^1.42.0"
  }
}
