{
  "name": "oxlint-vize-example",
  "private": true,
  "type": "module",
  "scripts": {
    "build:deps": "vp run --workspace-root build:native && sh -c 'cd ../../npm/oxlint-plugin-vize && vp pack'",
    "prelint": "vp run build:deps",
    "prelint:clean": "vp run build:deps",
    "prelint:with-help": "vp run build:deps",
    "prelint:json": "vp run build:deps",
    "prelint:unused-vars-probe": "vp run build:deps",
    "lint": "time vp exec oxlint -c .oxlintrc.json -f stylish src",
    "lint:clean": "vp exec oxlint -c .oxlintrc.json -f stylish src/Clean.vue",
    "lint:with-help": "vp exec oxlint -c .oxlintrc.help.json -f stylish src",
    "lint:json": "vp exec oxlint -c .oxlintrc.json -f json src",
    "lint:unused-vars-probe": "vp exec oxlint -c .oxlintrc.unused-vars.json -f stylish src/UnusedVarProbe.vue"
  },
  "devDependencies": {
    "oxlint": "^1.42.0"
  }
}
