  {
    "file": "packages/core/src/Switch/Switch.story.vue",
    "messages": [
      {
        "ruleId": "vue/multi-word-component-names",
        "severity": 2,
        "message": "[vize:vue/multi-word-component-names] Component name \"{name}\" should be multi-word to avoid conflicts with HTML elements",
        "line": 1,
        "column": 239,
        "endLine": 1,
        "endColumn": 239,
