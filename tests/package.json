{
  "name": "@vize/tests",
  "private": true,
  "type": "module",
  "scripts": {
    "test:dev": "playwright test --config app/playwright.config.ts",
    "test:preview": "node --experimental-strip-types app/preview/elk.ts && node --experimental-strip-types app/preview/misskey.ts && node --experimental-strip-types app/preview/npmx.ts && node --experimental-strip-types app/preview/vuefes.ts",
    "test:check": "node --experimental-strip-types --test snapshots/check/elk.ts snapshots/check/misskey.ts snapshots/check/npmx.ts snapshots/check/vuefes.ts",
    "test:lint": "node --experimental-strip-types --test snapshots/lint/elk.ts snapshots/lint/misskey.ts snapshots/lint/npmx.ts snapshots/lint/vuefes.ts",
    "test:build": "node --experimental-strip-types --test snapshots/build/elk.ts snapshots/build/misskey.ts snapshots/build/npmx.ts snapshots/build/vuefes.ts",
    "test:check:fixtures": "node --experimental-strip-types --test snapshots/check/typecheck-errors.ts snapshots/check/compiler-macros.ts snapshots/check/style-preprocessors.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
