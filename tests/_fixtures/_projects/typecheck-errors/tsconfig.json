{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "vue": ["../../../../node_modules/vue"],
      "vue/*": ["../../../../node_modules/vue/*"]
    }
  },
  "include": ["src/**/*.vue"]
}
