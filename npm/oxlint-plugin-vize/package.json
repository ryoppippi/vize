{
  "name": "oxlint-plugin-vize",
  "version": "0.33.0",
  "description": "Oxlint JS plugin bridge for Vize Patina",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "oxlint-vize": "bin/oxlint-vize"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "vp pack",
    "test": "vp pack && node --experimental-strip-types src/test.ts",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize",
    "directory": "npm/oxlint-plugin-vize"
  },
  "keywords": [
    "oxlint",
    "plugin",
    "vue",
    "vize",
    "lint"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@oxlint/plugins": "^1.53.0"
  },
  "optionalDependencies": {
    "@vizejs/native-darwin-arm64": "0.0.1-alpha.114",
    "@vizejs/native-darwin-x64": "0.0.1-alpha.114",
    "@vizejs/native-linux-arm64-gnu": "0.0.1-alpha.114",
    "@vizejs/native-linux-arm64-musl": "0.0.1-alpha.114",
    "@vizejs/native-linux-x64-gnu": "0.0.1-alpha.114",
    "@vizejs/native-linux-x64-musl": "0.0.1-alpha.114",
    "@vizejs/native-win32-arm64-msvc": "0.0.1-alpha.114",
    "@vizejs/native-win32-x64-msvc": "0.0.1-alpha.114"
  },
  "devDependencies": {
    "@vizejs/native": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "~5.6.0",
    "vite-plus": "catalog:"
  }
}
